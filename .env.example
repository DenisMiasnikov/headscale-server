# Docker Hub username used for pulling images
# Default set by install.sh, change if you use a different account
DOCKER_USERNAME=lykabala

# Your public domain (e.g., homelab.example.com)
DOMAIN=your-domain.com

# Server URL (should match DOMAIN, usually https://DOMAIN)
SERVER_URL=https://your-domain.com

# MagicDNS base domain (Tailscale's .tail domain)
BASE_DOMAIN=tail.your-domain.com

# Default headscale namespace
DEFAULT_USER=default

# UI admin credentials
UI_USERNAME=admin
UI_PASSWORD=change_me

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me

# Whether cookies should be secure (true for HTTPS, false for local HTTP)
COOKIE_SECURE=true

# Email for Let's Encrypt SSL certificate
LETSENCRYPT_EMAIL=your-email@example.com
